<!-- ================= BLENDER SOURCE (成果物には表示されない、非表示の作品プール) ================= -->
<!-- ★ Blenderの作品を増やしたい時は、この中に .card をコピーして増やしてください。
     ここに書いたカードは「成果物」セクションには出ず、「Blenderまとめ」画面にだけ表示されます。 -->
<div id="blenderSource" hidden>

  <article class="card" data-tag="blender" data-difficult="ここに『難しかった点』を書きます。作業のどこでつまずいたか、どう試行錯誤したかなど。" data-favorite="ここに『好きな点』を書きます。完成して満足しているポイントや、こだわった部分など。">
    <div class="tape"></div>
    <div class="card-thumb thumb-coral">Aa</div>
    <span class="card-tag">BLENDER</span>
    <h3 class="card-title">blender</h3>
    <p>これまで制作したblenderの一覧</p>
  </article>

  <article class="card" data-tag="blender" data-difficult="ここに『難しかった点』を書きます。作業のどこでつまずいたか、どう試行錯誤したかなど。" data-favorite="ここに『好きな点』を書きます。完成して満足しているポイントや、こだわった部分など。">
    <div class="tape"></div>
    <div class="card-thumb thumb-teal">◆</div>
    <span class="card-tag">blender</span>
    <h3 class="card-title">作品タイトル</h3>
