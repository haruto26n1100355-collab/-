    <a class="btn-mail" href="mailto:hello@example.com">メールを送る</a>
    <div class="sns-row">
      <!-- ★ SNSリンクをここに -->
      <a href="#">Instagram</a>
      <a href="#">X (Twitter)</a>
      <a href="#">Behance</a>
    </div>
  </section>

</main>

<footer>
  © 2026 Haruto uchida. Made with a little bit of paper and glue.
</footer>

</div><!-- /#view-portfolio -->

<!-- ================= BLENDER SOURCE (成果物には表示されない、非表示の作品プール) ================= -->
<!-- ★ Blenderの作品を増やしたい時は、この中に .card をコピーして増やしてください。
     ここに書いたカードは「成果物」セクションには出ず、「Blenderまとめ」画面にだけ表示されます。 -->
<div id="blenderSource" hidden>

  <article class="card card-intro" data-tag="blender">
    <div class="tape"></div>
    <div class="card-thumb thumb-coral card-thumb-img">
      <img src="data:image/jpeg;base64," alt="Blenderアイコン">
    </div>
    <span class="card-tag">BLENDER</span>
    <h3 class="card-title">blender</h3>
